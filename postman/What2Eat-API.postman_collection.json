    {
      "name": "DeepSeek (Direct)",
      "description": "Direct calls to DeepSeek API — bypasses What2Eat backend.\n\nSet `deepseekApiKey` in environment (same as `AI_API_KEY` in `.env`).\n\nUse these to:\n- Verify API key and balance\n- Inspect `usage.prompt_cache_hit_tokens` / `prompt_cache_miss_tokens`\n- Test recipe JSON output before going through the backend",
      "item": [
        {
          "name": "Ping — Simple Completion",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{deepseekApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{aiModel}}\",\n  \"messages\": [\n    { \"role\": \"user\", \"content\": \"Reply with exactly: OK\" }\n  ],\n  \"temperature\": {{aiTemperature}},\n  \"max_tokens\": 10,\n  \"stream\": false\n}"
            },
            "url": "{{deepseekBaseUrl}}/chat/completions",
            "description": "Minimal request to verify API key, connectivity, and balance.\n\nExpected: 200 with `choices[0].message.content` containing \"OK\"."
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const key = pm.environment.get('deepseekApiKey') || pm.collectionVariables.get('deepseekApiKey');",
                  "if (!key) {",
                  "  console.warn('Set deepseekApiKey in environment (from AI_API_KEY in .env)');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('DeepSeek reachable', () => {",
                  "  pm.expect([200, 401, 402]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  const usage = pm.response.json().usage;",
                  "  if (usage) {",
                  "    console.log('prompt_tokens:', usage.prompt_tokens);",
                  "    console.log('completion_tokens:', usage.completion_tokens);",
                  "    console.log('cache_hit:', usage.prompt_cache_hit_tokens ?? 0);",
                  "    console.log('cache_miss:', usage.prompt_cache_miss_tokens ?? 0);",
                  "  }",
                  "}",
                  "",
                  "if (pm.response.code === 402) {",
                  "  console.error('Insufficient balance — top up at platform.deepseek.com');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Recipe JSON — Same as Backend",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{deepseekApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{aiModel}}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"شما یک آشپز فارسی هستید. فقط JSON معتبر برگردانید با کلیدهای title, description, ingredients, instructions, calories, prepTime, cookTime, servings, category.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"یک دستور پخت برای مواد: گوجه، پیاز. فقط با این ابزارها: تابه. سقف کالری کل غذا (همه‌ی پرس‌ها): حداکثر 500 کالری. برای 2 نفر\"\n    }\n  ],\n  \"response_format\": { \"type\": \"json_object\" },\n  \"temperature\": {{aiTemperature}},\n  \"stream\": false\n}"
            },
            "url": "{{deepseekBaseUrl}}/chat/completions",
            "description": "Mirrors the backend request shape (`response_format: json_object`, temperature from env).\n\nRun twice with the **same system prompt** to observe cache hits in the Console tab."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "const content = json.choices?.[0]?.message?.content;",
                  "",
                  "pm.test('Returns JSON content', () => {",
                  "  pm.expect(content).to.be.a('string');",
                  "  JSON.parse(content);",
                  "});",
                  "",
                  "const usage = json.usage;",
                  "if (usage) {",
                  "  const hit = usage.prompt_cache_hit_tokens ?? 0;",
                  "  const miss = usage.prompt_cache_miss_tokens ?? 0;",
                  "  const total = usage.prompt_tokens ?? (hit + miss);",
                  "  const hitRate = total > 0 ? Math.round((hit / total) * 100) : 0;",
                  "",
                  "  console.log('--- DeepSeek Usage ---');",
                  "  console.log('prompt_tokens:', usage.prompt_tokens);",
                  "  console.log('completion_tokens:', usage.completion_tokens);",
                  "  console.log('total_tokens:', usage.total_tokens);",
                  "  console.log('cache_hit_tokens:', hit);",
                  "  console.log('cache_miss_tokens:', miss);",
                  "  console.log('cache_hit_rate:', hitRate + '%');",
                  "",
                  "  pm.test('Usage includes cache fields', () => {",
                  "    pm.expect(usage).to.have.property('prompt_cache_hit_tokens');",
                  "    pm.expect(usage).to.have.property('prompt_cache_miss_tokens');",
                  "  });",
                  "}",
                  "",
                  "if (content) {",
                  "  const recipe = JSON.parse(content);",
                  "  console.log('Recipe title:', recipe.title);",
                  "  console.log('Calories:', recipe.calories);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Recipe JSON — Cache Test (run 2x)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{deepseekApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{aiModel}}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"CACHE_TEST_FIXED_PREFIX — You are a Persian chef. Return only valid JSON with keys: title, description, ingredients, instructions, calories, prepTime, cookTime, servings, category. Numeric fields must be JSON numbers.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Suggest a recipe for: گوجه\"\n    }\n  ],\n  \"response_format\": { \"type\": \"json_object\" },\n  \"temperature\": {{aiTemperature}},\n  \"stream\": false\n}"
            },
            "url": "{{deepseekBaseUrl}}/chat/completions",
            "description": "Send this request **twice in a row** with identical body.\n\n- 1st call: expect `cache_hit_tokens ≈ 0`\n- 2nd call: expect `cache_hit_tokens` high on the system prefix\n\nCheck Postman Console (View → Show Postman Console)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const usage = pm.response.json().usage;",
                  "if (usage) {",
                  "  const hit = usage.prompt_cache_hit_tokens ?? 0;",
                  "  console.log('cache_hit_tokens this request:', hit);",
                  "  if (hit === 0) {",
                  "    console.log('Tip: Run this same request again — cache_hit should increase.');",
                  "  } else {",
                  "    console.log('Cache is working — prefix was served from disk cache.');",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Flows",
      "description": "Run folder with Collection Runner for end-to-end smoke test.",
      "item": [
        {
          "name": "1. Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "response": []
        },
        {
          "name": "2. Request OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"{{mobileNumber}}\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/otp/request"
          },
          "response": []
        },
        {
          "name": "3. Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"{{mobileNumber}}\",\n  \"otpCode\": \"{{otpCode}}\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/otp/verify"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.accessToken) pm.collectionVariables.set('accessToken', body.accessToken);",
                  "if (body.refreshToken) pm.collectionVariables.set('refreshToken', body.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Generate Recipe",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ingredients\": [\"گوجه\", \"پیاز\"],\n  \"tools\": [\"تابه\"],\n  \"calorieLimit\": 500,\n  \"servings\": 2\n}"
            },
            "url": "{{baseUrl}}/api/recipes/generate"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const id = pm.response.json().data?.id;",
                  "if (id) pm.collectionVariables.set('recipeId', id);"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Get Recipe",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/recipes/{{recipeId}}"
          },
          "response": []
        }
      ]
    }
  ]
}
